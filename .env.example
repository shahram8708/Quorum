FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-min-32-chars-change-this
DEV_DATABASE_URL=sqlite:///quorum_dev.db
DATABASE_URL=postgresql://quorum_user:password@localhost/quorum_prod

# Email (use Mailtrap for dev)
MAIL_SERVER=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_DEFAULT_SENDER=noreply@quorum.org

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=quorum-feed-files-dev
AWS_S3_REGION=ap-south-1
USE_S3=False
LOCAL_STORAGE_PATH=local_storage

# Razorpay (NOT Stripe)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_CREATOR_PRO_AMOUNT=74900
RAZORPAY_ORG_STARTER_AMOUNT=499900
RAZORPAY_ORG_TEAM_AMOUNT=1499900

# Google Gemini AI
GOOGLE_API_KEY=your_google_genai_api_key

# App Config
BASE_URL=http://localhost:5000
FREE_TIER_MAX_ACTIVE_PROJECTS=2
FREE_TIER_MAX_TEAM_SIZE=8
FREE_TIER_MAX_TIMELINE_DAYS=60
DIGEST_EMAIL_DAY=1
MAX_FILE_SIZE_MB=10
AUTO_CREATE_DB=True
AUTO_CREATE_ADMIN_ON_STARTUP=True
AUTO_SEED_DATA_ON_STARTUP=True
ADMIN_EMAIL=admin@quorum.local
ADMIN_PASSWORD=Admin@12345678
ADMIN_USERNAME=quorum_admin
ADMIN_FIRST_NAME=Quorum
ADMIN_LAST_NAME=Admin

# Optional
GOOGLE_MAPS_API_KEY=your_maps_key
SENTRY_DSN=your_sentry_dsn
